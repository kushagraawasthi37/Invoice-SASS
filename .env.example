# ─── APPLICATION ─────────────────────────────────────────────────

NODE_ENV=development
PORT=4000
FRONTEND_URL=http://localhost:3000

# ─── DATABASE ────────────────────────────────────────────────────
DATABASE_URL=postgresql://invoiceflow:secret@localhost:5432/invoiceflow?schema=public

# ─── JWT ─────────────────────────────────────────────────────────
JWT_SECRET=change-me-to-a-long-random-string-at-least-64-chars
JWT_REFRESH_SECRET=change-me-to-another-long-random-string-at-least-64-chars
JWT_EXPIRES_IN=15m
JWT_REFRESH_EXPIRES_IN=7d

# ─── GOOGLE OAUTH ────────────────────────────────────────────────
GOOGLE_CLIENT_ID=your-google-client-id
GOOGLE_CLIENT_SECRET=your-google-client-secret
GOOGLE_CALLBACK_URL=http://localhost:4000/api/v1/auth/google/callback

# ─── STRIPE ──────────────────────────────────────────────────────
STRIPE_SECRET_KEY=sk_test_...
STRIPE_WEBHOOK_SECRET=whsec_...
STRIPE_PRO_MONTHLY_PRICE_ID=price_...
STRIPE_PRO_YEARLY_PRICE_ID=price_...

# ─── AWS S3 ──────────────────────────────────────────────────────
AWS_ACCESS_KEY_ID=your-access-key-id
AWS_SECRET_ACCESS_KEY=your-secret-access-key
AWS_REGION=ap-southeast-2
AWS_S3_BUCKET=invoiceflow-uploads

# ─── EMAIL (SMTP / SendGrid) ─────────────────────────────────────
SMTP_HOST=smtp.sendgrid.net
SMTP_PORT=587
SMTP_USER=apikey
SMTP_PASS=SG.xxx
EMAIL_FROM=noreply@invoiceflow.app
EMAIL_FROM_NAME=InvoiceFlow

# ─── REDIS (optional - for rate limiting / sessions) ─────────────
REDIS_URL=redis://localhost:6379

# ─── LOGGING ─────────────────────────────────────────────────────
LOG_LEVEL=info
