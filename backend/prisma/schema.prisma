generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ─────────────────────────────────────────────
// ENUMS
// ─────────────────────────────────────────────

enum UserRole {
  USER
  ADMIN
}

enum SubscriptionPlan {
  FREE
  PRO_MONTHLY
  PRO_YEARLY
}

enum SubscriptionStatus {
  ACTIVE
  TRIALING
  PAST_DUE
  CANCELED
  UNPAID
}

enum InvoiceStatus {
  DRAFT
  SENT
  PAID
  VOID
  OVERDUE
}

enum DocumentType {
  INVOICE
  QUOTE
  PURCHASE_ORDER
}

enum TemplateScope {
  SYSTEM
  USER
}

enum AnalysisStatus {
  PENDING
  PROCESSING
  READY
  FAILED
}

enum RecurringFrequency {
  WEEKLY
  FORTNIGHTLY
  MONTHLY
  QUARTERLY
  YEARLY
}

// ─────────────────────────────────────────────
// USER
// ─────────────────────────────────────────────

model User {
  id                String    @id @default(cuid())
  email             String    @unique
  passwordHash      String?
  name              String
  avatarUrl         String?
  googleId          String?   @unique
  emailVerified     Boolean   @default(false)
  emailVerifyToken  String?
  resetPasswordToken      String?
  resetPasswordExpires    DateTime?
  role              UserRole  @default(USER)
  createdAt         DateTime  @default(now())
  updatedAt         DateTime  @updatedAt

  // Relations
  workspace         Workspace?
  refreshTokens     RefreshToken[]

  @@index([email])
  @@map("users")
}

model RefreshToken {
  id        String   @id @default(cuid())
  token     String   @unique
  userId    String
  expiresAt DateTime
  createdAt DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([token])
  @@index([userId])
  @@map("refresh_tokens")
}

// ─────────────────────────────────────────────
// WORKSPACE (one-per-user tenant)
// ─────────────────────────────────────────────

model Workspace {
  id          String  @id @default(cuid())
  userId      String  @unique
  // Business Profile
  bizName     String  @default("")
  abn         String  @default("")
  email       String  @default("")
  phone       String  @default("")
  address     String  @default("")
  website     String  @default("")
  // Labels
  providerLabel  String @default("Provider")
  clientLabel    String @default("NDIS Participant")
  // Defaults for new invoices
  defaultProviderTitle  String  @default("Support Worker")
  defaultClientName     String  @default("")
  defaultDescription    String  @default("Support Services")
  defaultRate           Decimal @default(50.00) @db.Decimal(10, 2)
  // Invoice numbering
  invoicePrefix  String  @default("INV")
  nextNumber     Int     @default(1)
  currency       String  @default("AUD")
  // Branding
  logoUrl        String?
  brandColor     String  @default("#2c5f2e")
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  // Relations
  user              User               @relation(fields: [userId], references: [id], onDelete: Cascade)
  subscription      Subscription?
  invoices          Invoice[]
  templates         Template[]
  recurringInvoices RecurringInvoice[]
  clients           Client[]
  usageTracking     UsageTracking?

  @@map("workspaces")
}

// ─────────────────────────────────────────────
// SUBSCRIPTION
// ─────────────────────────────────────────────

model Subscription {
  id                   String             @id @default(cuid())
  workspaceId          String             @unique
  stripeCustomerId     String?            @unique
  stripeSubscriptionId String?            @unique
  stripePriceId        String?
  plan                 SubscriptionPlan   @default(FREE)
  status               SubscriptionStatus @default(ACTIVE)
  currentPeriodStart   DateTime?
  currentPeriodEnd     DateTime?
  cancelAtPeriodEnd    Boolean            @default(false)
  trialEndsAt          DateTime?
  createdAt            DateTime           @default(now())
  updatedAt            DateTime           @updatedAt

  workspace Workspace @relation(fields: [workspaceId], references: [id], onDelete: Cascade)

  @@index([stripeCustomerId])
  @@index([stripeSubscriptionId])
  @@map("subscriptions")
}

// ─────────────────────────────────────────────
// USAGE TRACKING
// ─────────────────────────────────────────────

model UsageTracking {
  id             String   @id @default(cuid())
  workspaceId    String   @unique
  pdfDownloads   Int      @default(0)
  invoicesCreated Int     @default(0)
  resetAt        DateTime @default(now())
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  workspace Workspace @relation(fields: [workspaceId], references: [id], onDelete: Cascade)

  @@map("usage_tracking")
}

// ─────────────────────────────────────────────
// CLIENT (contact book)
// ─────────────────────────────────────────────

model Client {
  id                String  @id @default(cuid())
  workspaceId       String
  name              String
  ndisNumber        String  @default("")
  email             String  @default("")
  phone             String  @default("")
  address           String  @default("")
  planManager       String  @default("")
  supportCoordinator String @default("")
  legalGuardian     String  @default("")
  notes             String  @default("")
  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt

  workspace Workspace @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  invoices  Invoice[]

  @@index([workspaceId])
  @@map("clients")
}

// ─────────────────────────────────────────────
// INVOICE
// ─────────────────────────────────────────────

model Invoice {
  id           String        @id @default(cuid())
  workspaceId  String
  clientId     String?
  type         DocumentType  @default(INVOICE)
  number       String
  status       InvoiceStatus @default(DRAFT)
  // Dates
  issueDate    DateTime
  dueDate      DateTime?
  serviceMonth String?       // "2026-01" format
  // Provider snapshot (denormalised at creation time)
  providerName     String @default("")
  providerTitle    String @default("")
  providerAddress  String @default("")
  providerEmail    String @default("")
  providerPhone    String @default("")
  providerABN      String @default("")
  // Client snapshot
  clientName       String @default("")
  clientAddress    String @default("")
  clientEmail      String @default("")
  ndisNumber       String @default("")
  fiscalAgent      String @default("")
  supportCoordinator String @default("")
  legalGuardian    String @default("")
  bsbAccount       String @default("")
  // Signatures (base64 data URLs stored in S3, URL stored here)
  clientSigUrl     String?
  providerSigUrl   String?
  // Totals (computed, stored for querying)
  totalHours       Decimal  @default(0) @db.Decimal(10, 2)
  subtotal         Decimal  @default(0) @db.Decimal(10, 4)
  gstAmount        Decimal  @default(0) @db.Decimal(10, 4)
  totalAmount      Decimal  @default(0) @db.Decimal(10, 4)
  currency         String   @default("AUD")
  // Template
  templateId       String?
  // Notes
  notes            String   @default("")
  // PDF cache
  pdfUrl           String?
  pdfGeneratedAt   DateTime?
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt

  workspace    Workspace     @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  client       Client?       @relation(fields: [clientId], references: [id])
  template     Template?     @relation(fields: [templateId], references: [id])
  lineItems    InvoiceLineItem[]
  recurringInvoice RecurringInvoice? @relation(fields: [recurringId], references: [id])
  recurringId  String?

  @@unique([workspaceId, number])
  @@index([workspaceId])
  @@index([clientId])
  @@index([status])
  @@map("invoices")
}

// ─────────────────────────────────────────────
// INVOICE LINE ITEMS
// ─────────────────────────────────────────────

model InvoiceLineItem {
  id          String   @id @default(cuid())
  invoiceId   String
  sortOrder   Int      @default(0)
  serviceDate DateTime?
  startTime   String   @default("") // "09:00"
  endTime     String   @default("") // "17:00"
  description String   @default("")
  hours       Decimal  @default(0) @db.Decimal(10, 2)
  rate        Decimal  @default(0) @db.Decimal(10, 2)
  amount      Decimal  @default(0) @db.Decimal(10, 4)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  invoice Invoice @relation(fields: [invoiceId], references: [id], onDelete: Cascade)

  @@index([invoiceId])
  @@map("invoice_line_items")
}

// ─────────────────────────────────────────────
// TEMPLATE
// ─────────────────────────────────────────────

model Template {
  id              String         @id @default(cuid())
  workspaceId     String?
  scope           TemplateScope  @default(USER)
  name            String
  description     String         @default("")
  thumbnailUrl    String?
  // Original uploaded PDF (stored in S3)
  originalPdfKey  String?
  originalPdfUrl  String?
  pageCount       Int            @default(1)
  // AI analysis result
  analysisStatus      AnalysisStatus @default(PENDING)
  analysisJson        Json?          // raw extraction: text items, acroform fields, positions
  fieldMappings       Json?          // semantic mappings: label → invoiceField + fill coords
  analysisError       String?
  templateFingerprint String?        // hash for detecting similar templates
  mappingMemory       Json?          // learned corrections and aliases from user feedback
  // Visual / UI
  isDefault       Boolean        @default(false)
  brandColor      String         @default("#2c5f2e")
  fontFamily      String         @default("DM Sans")
  createdAt       DateTime       @default(now())
  updatedAt       DateTime       @updatedAt

  workspace Workspace? @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  invoices  Invoice[]

  @@index([workspaceId])
  @@index([scope])
  @@map("templates")
}

// ─────────────────────────────────────────────
// RECURRING INVOICES
// ─────────────────────────────────────────────

model RecurringInvoice {
  id           String             @id @default(cuid())
  workspaceId  String
  frequency    RecurringFrequency
  nextRunAt    DateTime
  lastRunAt    DateTime?
  isActive     Boolean            @default(true)
  // Template data stored as JSON
  templateData Json
  createdAt    DateTime           @default(now())
  updatedAt    DateTime           @updatedAt

  workspace Workspace @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  invoices  Invoice[]

  @@index([workspaceId])
  @@index([nextRunAt])
  @@map("recurring_invoices")
}
